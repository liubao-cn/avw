{
  "productName": "AVW",
  "version": "1.5.6",
  "identifier": "cn.liubao.avw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AVW",
        "width": 1100,
        "height": 780,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; connect-src ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    },
    "linux": {
      "deb": {
        "depends": [
          "xdg-utils",
          "libwebkit2gtk-4.0-0 | libwebkit2gtk-4.1-0"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
